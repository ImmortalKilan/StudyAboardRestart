  {
    "id": 99041,
    "storyline": "xianxia",
    "text": "金丹愈发圆润，你呼吸间已能御气而行。",
    "include": "cul>=60&cul<150",
    "effect": {
      "cul": 3
    }
  },
  {
    "id": 99042,
    "storyline": "xianxia",
    "text": "你云游四方，看见凡间种种悲欢，心境又精进一分。",
