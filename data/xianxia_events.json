    "effect": {
      "cul": 8,
      "karma": 1
    }
  },
  {
    "id": 99029,
    "storyline": "xianxia",
    "text": "你在静室中盘膝七日，体内灵息汇聚成丹海，又复归流转周身经脉，形成灵脉。",
    "include": "cul>=40",
    "weight": 40,
    "effect": {
      "cul": 5
    }
  },
  {
    "id": 99030,
    "storyline": "xianxia",
    "text": "心中泛起阴影，那是凡尘留下的牵挂。",
    "include": "HAP<=3&cul<150",
    "weight": 40,
    "effect": {
      "cul": -2,
      "HAP": -1
    }
  },
  {
    "id": 99039,
    "storyline": "xianxia",
    "text": "你尝试冲击金丹。",
